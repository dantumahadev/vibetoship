# Google Gemini API (Get from https://aistudio.google.com/apikey)
GEMINI_API_KEY="your_gemini_api_key_here"

# Server Configuration
PORT=3001
APP_URL="http://localhost:3001"
PUBLIC_URL="http://localhost:3001"

# Twilio WhatsApp Integration (Optional - Get from https://console.twilio.com/)
TWILIO_ACCOUNT_SID="your_twilio_account_sid"
TWILIO_AUTH_TOKEN="your_twilio_auth_token"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"

# SMTP Email Configuration (Gmail recommended)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"

# Google Cloud Vertex AI Agent (Optional - Get from Google Cloud Console)
VERTEX_PROJECT_ID="your-gcp-project-id"
VERTEX_AGENT_ID="your-vertex-agent-id"
VERTEX_AGENT_LOCATION="us-central1"
